{
  "permissions": {
    "allow": [
      "Bash(make test)",
      "Bash(make lint)",
      "Bash(make stim)",
      "Bash(make compile)",
      "Bash(make sim)",
      "Bash(make compare)",
      "Bash(make clean)",
      "Bash(verible-verilog-lint:*)",
      "Bash(verible-verilog-format:*)",
      "Bash(vcs:*)",
      "Bash(python3 scripts/gen_stim.py:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git stash)",
      "Bash(git branch)",
      "Edit(rtl/*.sv)",
      "Write(rtl/*.sv)",
      "Edit(PROGRESS.md)",
      "Write(PROGRESS.md)",
      "Read(*)"
    ],
    "ask": [
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git branch -d:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Edit(tb/*.sv)",
      "Edit(Makefile)",
      "Write(*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D:*)",
      "Bash(rm -rf:*)",
      "Edit(ref/fec_encoder/ref_model.py)",
      "Write(ref/fec_encoder/ref_model.py)",
      "Edit(ref/puncturing/ref_model.py)",
      "Write(ref/puncturing/ref_model.py)",
      "Edit(ref/symbol_mapper/ref_model.py)",
      "Write(ref/symbol_mapper/ref_model.py)",
      "Edit(W1/modules/fec_encoder.md)",
      "Write(W1/modules/fec_encoder.md)",
      "Edit(W1/modules/interval_spacing.md)",
      "Write(W1/modules/interval_spacing.md)",
      "Edit(W1/modules/puncturing.md)",
      "Write(W1/modules/puncturing.md)",
      "Edit(W1/modules/srrc_upsample.md)",
      "Write(W1/modules/srrc_upsample.md)",
      "Edit(W1/modules/symbol_assembler.md)",
      "Write(W1/modules/symbol_assembler.md)",
      "Edit(W1/modules/symbol_mapper.md)",
      "Write(W1/modules/symbol_mapper.md)",
      "Edit(W1/modules/tx_ctrl_fsm.md)",
      "Write(W1/modules/tx_ctrl_fsm.md)",
      "Edit(W1/00_toplevel.md)",
      "Write(W1/00_toplevel.md)",
      "Edit(W1/README.md)",
      "Write(W1/README.md)",
      "Edit(W1/SKILL.md)",
      "Write(W1/SKILL.md)",
      "Edit(W1/_TEMPLATE_module.md)",
      "Write(W1/_TEMPLATE_module.md)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_edit_sv.sh"
          }
        ]
      }
    ]
  },
  "disabledHooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_force_test.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start_progress.sh"
          }
        ]
      }
    ]
  }
}
